APP_ENV=development

BACKEND_PORT=8080
FRONTEND_PORT=3000

# Use a long random value. The Windows setup script generates one automatically.
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=8h

ADMIN_USERNAME=admin
# Generate from code/server with: go run ./cmd/hash-password "change-me"
ADMIN_PASSWORD_HASH=$2a$10$replace.this.with.a.real.bcrypt.hash.before.running

# Server-only credential. Never expose this through Vite/frontend variables.
WHOISFREAKS_API_KEY=replace-with-api-key
WHOISFREAKS_BASE_URL=https://api.whoisfreaks.com/v1.0

DOMAIN_CHECK_CONCURRENCY=5
DOMAIN_CHECK_TIMEOUT_SECONDS=10
DOMAIN_CHECK_MAX_RETRIES=2

JOB_RETENTION_MINUTES=30
JOB_CLEANUP_INTERVAL_MINUTES=5

# Comma-separated when more than one local origin is needed.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Required only with: docker compose --profile tunnel up
CLOUDFLARE_TUNNEL_TOKEN=
PUBLIC_APP_URL=
